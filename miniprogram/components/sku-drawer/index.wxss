/* SKU 规格选择抽屉组件 - 深色主题 */
.sku-drawer {
  padding: 40rpx 32rpx calc(env(safe-area-inset-bottom) + 32rpx);
}

/* 头部 */
.sku-header {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.sku-header-thumb {
  flex-shrink: 0;
}
.sku-header-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}
.sku-price {
  font-size: 40rpx;
  color: #ff6a45;
  font-weight: bold;
}
.sku-selected-name {
  font-size: 26rpx;
  color: #ccc;
}
.sku-stock {
  font-size: 24rpx;
  color: #999;
}

/* 规格区域 */
.sku-section {
  margin-bottom: 32rpx;
}
.sku-section-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 20rpx;
}
.sku-pkg-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.sku-pkg-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid #333;
  background: #2a2a2a;
}
.sku-pkg-item.selected {
  border-color: #ff6a45;
  background: rgba(255, 106, 69, 0.1);
}
.sku-pkg-item.disabled {
  opacity: 0.4;
}
.sku-pkg-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.sku-pkg-name {
  font-size: 26rpx;
  color: #fff;
}
.sku-pkg-desc {
  font-size: 22rpx;
  color: #999;
  display: -webkit-box;
  line-clamp: 2;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.sku-pkg-price {
  font-size: 24rpx;
  color: #ff6a45;
}
.sku-pkg-sold-out {
  font-size: 22rpx;
  color: #ff4d4f;
  flex-shrink: 0;
}

/* 数量区域 */
.sku-quantity-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 32rpx 0 40rpx;
}
.sku-quantity-label {
  font-size: 28rpx;
  color: #fff;
}

/* 方形数量选择器 */
.qty-stepper {
  display: inline-flex;
  align-items: center;
  border: 1rpx solid #444;
  border-radius: 8rpx;
  overflow: hidden;
}
.qty-btn {
  width: 64rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
  background: #2a2a2a;
}
.qty-btn:active {
  background: rgba(255, 106, 69, 0.2);
}
.qty-btn.disabled {
  color: #555;
  background: #1a1a1a;
}
.qty-value {
  min-width: 72rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  background: #1a1a1a;
  border-left: 1rpx solid #444;
  border-right: 1rpx solid #444;
}

/* 操作按钮 */
.sku-btn-wrap {
  padding-top: 16rpx;
}
.sku-btn-bar {
  display: flex;
  border-radius: 48rpx;
  overflow: hidden;
  margin-top: 32rpx;
}
.sku-btn-bar.disabled {
  opacity: 0.5;
  pointer-events: none;
}
.sku-btn-bar-left {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff6a45;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}
.sku-btn-bar-left:active {
  opacity: 0.85;
}
.sku-btn-bar-right {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff4d4f;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}
.sku-btn-bar-right:active {
  opacity: 0.85;
}