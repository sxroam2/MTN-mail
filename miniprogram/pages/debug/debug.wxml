<view class="page">
  <view wx:if="{{loading}}" class="state-card">
    <van-loading color="#ff6a45" size="24px" />
    <text class="state-title">正在读取后台配置</text>
    <text class="state-desc">请稍候，调试页会自动同步最新协议。</text>
  </view>

  <view wx:elif="{{!hasAccess}}" class="state-card">
    <text class="state-title">{{emptyTitle}}</text>
    <text wx:if="{{userPhone}}" class="state-caption">当前手机号：{{userPhone}}</text>
    <text class="state-desc">{{emptyDescription}}</text>
  </view>

  <block wx:else>
    <view class="page-toolbar">
      <view class="toolbar-main">
        <text class="toolbar-title">蓝牙调试</text>
        <text class="toolbar-subtitle">当前账号 {{userPhone || '已登录'}}，实时扫描、连接和收包调试。</text>
      </view>
      <view class="toolbar-refresh" bindtap="refreshDebugConfig">
        <text>刷新配置</text>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <view>
          <text class="section-title">实时蓝牙连接</text>
          <text class="section-desc">蓝牙名称过滤 {{allowedDeviceNames.length}} 项，当前协议方案 {{profileSummaries.length}} 套。</text>
        </view>
      </view>

      <Bluetooth id="bluetoothCom" autoCheckAdapter="{{true}}" showHeader="{{false}}" />
    </view>

    <view class="section-card">
      <view class="section-head section-head-toggle" bindtap="toggleProtocolPanel">
        <view>
          <text class="section-title">协议配置</text>
          <text class="section-desc">默认收起，按需查看后台生效的蓝牙名称过滤和协议方案。</text>
        </view>
        <view class="toggle-pill">
          <text>{{showProtocolPanel ? '收起' : '展开'}}</text>
        </view>
      </view>

      <block wx:if="{{showProtocolPanel}}">
        <view class="compact-block">
          <text class="compact-label">蓝牙名称过滤</text>
          <view wx:if="{{allowedDeviceNames.length}}" class="tag-list">
            <text wx:for="{{allowedDeviceNames}}" wx:key="*this" class="tag-chip">{{item}}</text>
          </view>
          <text wx:else class="section-empty">当前未限制蓝牙名称，搜索结果会显示所有设备。</text>
        </view>

        <view class="compact-block">
          <text class="compact-label">协议方案</text>
          <scroll-view scroll-x enhanced show-scrollbar="{{false}}" class="profile-tabs">
            <view class="profile-tabs-inner">
              <view
                wx:for="{{profileSummaries}}"
                wx:key="key"
                class="profile-tab {{selectedProfileKey === item.key ? 'active' : ''}}"
                data-key="{{item.key}}"
                bindtap="selectProtocolProfile"
              >
                <text class="profile-tab-title">{{item.name}}</text>
                <text class="profile-tab-meta">{{item.commandCount}} 条协议</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <view wx:if="{{selectedProfileSummary}}" class="profile-detail-card">
          <view class="profile-top">
            <view class="profile-title-group">
              <text class="profile-title">{{selectedProfileSummary.name}}</text>
              <text wx:if="{{selectedProfileSummary.isDefault}}" class="profile-badge">默认兜底</text>
            </view>
            <text class="profile-meta">{{selectedProfileSummary.commandCount}} 条协议 · {{selectedProfileSummary.gaugeCount}} 个仪表盘</text>
          </view>

          <view class="tag-list">
            <text wx:if="{{!selectedProfileSummary.matchKeywords.length}}" class="subtle-chip">未命中其它方案时自动使用</text>
            <text
              wx:for="{{selectedProfileSummary.matchKeywords}}"
              wx:key="*this"
              wx:for-item="keyword"
              class="tag-chip tag-chip-muted"
            >{{keyword}}</text>
          </view>

          <view wx:if="{{selectedProfileSummary.gauges.length}}" class="gauge-list">
            <view
              wx:for="{{selectedProfileSummary.gauges}}"
              wx:key="key"
              wx:for-item="gauge"
              class="gauge-chip {{selectedGaugeKey === gauge.key ? 'active' : ''}}"
              data-key="{{gauge.key}}"
              bindtap="selectGaugeChip"
              hover-class="gauge-chip-hover"
            >
              <text class="gauge-chip-title">{{gauge.title}}</text>
              <text class="gauge-chip-meta">{{gauge.metricCount}} 项 · {{gauge.unit || '无单位'}}</text>
            </view>
          </view>

          <scroll-view wx:if="{{selectedProtocolCommands.length}}" scroll-y enhanced show-scrollbar="{{false}}" class="protocol-list">
            <view wx:for="{{selectedProtocolCommands}}" wx:key="key" wx:for-item="command" class="protocol-item">
              <view class="protocol-row">
                <text class="protocol-label">{{command.metricLabel}}</text>
                <text class="protocol-parser">{{command.parserLabel}}</text>
              </view>
              <view class="protocol-row protocol-row-secondary">
                <text class="protocol-code">CMD {{command.cmd}}</text>
                <text class="protocol-code">ACK {{command.ackCmd}}</text>
                <text wx:if="{{command.metricUnit}}" class="protocol-note">{{command.metricUnit}}</text>
                <text wx:if="{{command.scaleText}}" class="protocol-note">{{command.scaleText}}</text>
              </view>
            </view>
          </scroll-view>
          <text wx:else class="section-empty">当前仪表盘未配置可展示的协议数据。</text>
        </view>
      </block>
    </view>
  </block>
</view>