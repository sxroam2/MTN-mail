/* pages/equipment/equipment.wxss */
page {
  min-height: 100vh;
  height: 100vh;
  overflow: hidden;  /* 禁止页面滚动 */
  display: flex;
  justify-content: center;
}

.page {
  width: 100%;
  max-width: 750rpx;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow-y: auto;  /* 允许内部滚动 */
  overflow-x: hidden;
  position: relative;
  padding: 0;  /* 移除所有内边距 */
  margin: 0;   /* 移除所有外边距 */
}

.tip {
  width: 100%;
  text-align: center;
  padding: 30rpx 0 10rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
  flex-shrink: 0;
}

/* 波纹容器 - 默认居中 */
.ripple-container {
  position: relative;
  width: 600rpx;
  height: 600rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto;
  transition: all 0.3s ease-out;
  flex-shrink: 0;
}

/* 蓝牙开启时 - 缩小并上移，移除多余的margin */
.ripple-container.small {
  width: 300rpx;
  height: 300rpx;
  margin: 10rpx auto 0;
  transition: all 0.3s ease-out;
}

/* 基础波纹样式 */
.ripple {
  position: absolute;
  border-radius: 50%;
  background-color: rgba(255, 117, 0, 0.3);
  animation: ripple 2s ease-out infinite;
  pointer-events: none;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.ripple-1 {
  width: 400rpx;
  height: 400rpx;
  animation-delay: 0s;
}

.ripple-2 {
  width: 500rpx;
  height: 500rpx;
  animation-delay: 0.6s;
  opacity: 0.2;
}

.ripple-3 {
  width: 600rpx;
  height: 600rpx;
  animation-delay: 1.2s;
  opacity: 0.1;
}

/* 容器缩小时的波纹大小调整 */
.ripple-container.small .ripple-1 {
  width: 200rpx;
  height: 200rpx;
}

.ripple-container.small .ripple-2 {
  width: 250rpx;
  height: 250rpx;
}

.ripple-container.small .ripple-3 {
  width: 300rpx;
  height: 300rpx;
}

/* 波纹动画 */
@keyframes ripple {
  0% {
    opacity: 0.5;
  }
  100% {
    opacity: 0;
  }
}

/* 中心按钮容器 */
.box {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: transparent;
  position: relative;
  z-index: 10;
  cursor: pointer;
  transition: all 0.3s ease;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  position: absolute;
}

/* 容器缩小时的按钮大小调整 */
.ripple-container.small .box {
  width: 200rpx;
  height: 200rpx;
}

.box:active {
  transform: translate(-50%, -50%) scale(0.95);
}

.ripple-container.small .box:active {
  transform: translate(-50%, -50%) scale(0.95);
}

.main {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  background: #ff6a45;
  box-shadow: 0 10px 20px rgba(255, 106, 69, 0.3);
  transition: all 0.3s ease;
}

.image {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
  filter: brightness(0) invert(1);
  transition: all 0.3s ease;
}

/* 容器缩小时的图片大小调整 */
.ripple-container.small .image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  transition: all 0.3s ease;
}

/* 容器缩小时的文字大小调整 */
.ripple-container.small .text {
  font-size: 24rpx;
}

/* 设备列表区域 */
.device-section {
  width: 100%;
  padding: 10rpx 30rpx 0;
  box-sizing: border-box;
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.device-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.device-count {
  font-size: 26rpx;
  color: #ff6a45;
}

.device-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  border-color: #ff6a45 !important;
  color: #ff6a45 !important;
  font-size: 22rpx !important;
  height: 52rpx !important;
  line-height: 50rpx !important;
}

.device-list {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 20rpx;
  -webkit-overflow-scrolling: touch; /* iOS平滑滚动 */
  /* background-color: #000000; */
}

.device-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #1a1a1a;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  border: 1px solid #333;
  transition: all 0.2s ease;
}

/* 确保所有元素背景都是黑色 */
.device-item,
.empty-state,
.device-header,
.device-count,
.device-actions {
  background-color: transparent;
}

.device-item:active {
  background-color: #2a2a2a;
  transform: scale(0.98);
}

.device-info {
  flex: 1;
}

.device-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.device-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.device-id {
  font-size: 20rpx;
  color: #999;
}

.device-signal {
  text-align: right;
}

.rssi {
  font-size: 22rpx;
  color: #ff6a45;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 26rpx;
  gap: 20rpx;
}

/* 在 equipment.wxss 中添加过渡效果 */
.ripple-container {
  position: relative;
  width: 600rpx;
  height: 600rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto;
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); /* 弹性过渡效果 */
  flex-shrink: 0;
}

.ripple-container.small {
  width: 300rpx;
  height: 300rpx;
  margin: 20rpx auto 0;
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.box {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: transparent;
  position: relative;
  z-index: 10;
  cursor: pointer;
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  position: absolute;
}

.ripple-container.small .box {
  width: 200rpx;
  height: 200rpx;
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}