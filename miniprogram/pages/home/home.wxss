/* pages/home/home.wxss */

/* 顶部区域保持不变 */
.top {
  width: 100%;
}
.top-top {
  width: 100%;
}

.topleft-title {
  font-weight: 600;
  font-size: 24px;
  text-align: center;
  color: var(--fontColor);
  letter-spacing: 1px;
}

.top-center {
  width: 100%;
  height: 40vh;
  margin-top: 40rpx;
  padding: 0 24rpx 40rpx 0;
  box-sizing: border-box;
  position: relative;
  overflow: hidden; /* 防止图片溢出圆角 */
  border-radius: 16rpx; /* 如果你有圆角需求 */
}

/* 新增背景图样式 */
.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0; /* 确保在最底层 */
  display: block;
}

/* 确保内容在图片上面 */
.top .content {
  position: relative;
  z-index: 1; 
}

.carousel-swiper {
  width: 100%;
  height: 40vh;
  border-radius: 24rpx;
  overflow: hidden;
}

.carousel-image {
  width: 80%;
  height: 80%;
  margin-left: 10%;
  margin-top: 12%;
  object-fit: contain;
}

/* 轮播图指示点样式 */
.carousel-swiper .wx-swiper-dot {
  width: 8px;
  height: 8px;
  background-color: #9D9F9E;
  border-radius: 4px;
  margin: 0 4px;
  transition: all 0.3s ease;
}

.carousel-swiper .wx-swiper-dot-active {
  background-color: var(--btnColor);
}

/* 底部区域 */
.bottom {
  text-align: center;
  background-color: var(--backgroundColor);
  width: 100%;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.van-tabs__nav {
  background-color: var(--backgroundColor) !important;
}

.tab {
  min-height: 30vh;
  padding: 20rpx 0;
}

/* 设备列表区域 - 网格布局 */
.device-list-section {
  display: grid;
  grid-template-columns: repeat(auto-fill, 180rpx);
  gap: 40rpx;
  justify-content: center;
  padding: 20rpx 0 30rpx;
}

/* 设备卡片 */
.tab-item {
  position: relative;
  width: 180rpx;
  height: 240rpx;
  border-radius: 30rpx;
  border: 1px solid #333;
  background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
  transition: all 0.2s ease;
  cursor: pointer;
  overflow: hidden;
}

.tab-item.button-hover {
  transform: scale(0.96);
  background: linear-gradient(145deg, #1a1a1a, #2a2a2a);
  box-shadow: 0 3px 8px rgba(0, 0, 0, 0.4);
}

.tab-item.connected {
  border-color: #4cd964;
  box-shadow: 0 0 15px rgba(76, 217, 100, 0.2);
}

.tab-item.add-device {
  border-color: #ff6a45;
}

/* 按钮内部容器 */
.tab-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;  /* 改为从顶部开始排列 */
  width: 100%;
  height: 100%;
  position: relative;
  z-index: 2;
  padding: 30rpx 0 0;  /* 增加顶部内边距 */
}

/* 图片样式 */
.tab-image {
  width: 90rpx;
  height: 90rpx;
  margin-bottom: 16rpx;  /* 稍微减小图片底部间距 */
  filter: drop-shadow(0 4px 4px rgba(0, 0, 0, 0.3));
}

.tab-item.button-hover .tab-image {
  transform: translateY(2px);
}

/* 文字样式 */
.tab-text {
  font-size: 26rpx;
  font-weight: 500;
  letter-spacing: 1px;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  transition: all 0.2s ease;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  margin-bottom: 20rpx;  /* 添加底部间距，为device-status留出空间 */
}

.tab-item.button-hover .tab-text {
  color:  #ff6a45b9;
}

.add-device .tab-text {
  color: #ff6a45;
}

/* 设备状态区域 - 调整位置 */
.device-status {
  position: relative;  /* 改为相对定位 */
  bottom: auto;
  left: auto;
  right: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background-color: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(5px);
  padding: 6rpx 0;
  border-radius: 20rpx;
  width: 140rpx;  /* 固定宽度 */
  margin: 0 auto;  /* 水平居中 */
  margin-top: 0;  /* 不需要顶部边距，因为tab-text已经提供了间距 */
}

.status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: #4cd964;
  animation: pulse 1.5s infinite;
}

.status-text {
  font-size: 20rpx;
  color: #4cd964;
  font-weight: 500;
}

.drawer-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1200;
  background: rgba(0, 0, 0, 0.62);
  display: flex;
  align-items: flex-end;
}

.drawer-panel {
  width: 100%;
  padding: 18rpx 28rpx calc(env(safe-area-inset-bottom) + 24rpx);
  border-radius: 32rpx 32rpx 0 0;
  background: #111111;
  box-shadow: 0 -12rpx 36rpx rgba(0, 0, 0, 0.32);
  box-sizing: border-box;
}

.drawer-handle {
  width: 88rpx;
  height: 8rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
}

.drawer-header {
  padding: 24rpx 8rpx 16rpx;
  text-align: center;
}

.drawer-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.drawer-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 10rpx;
}

.drawer-action,
.drawer-cancel {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 22rpx;
}

.drawer-action {
  background: rgba(255, 255, 255, 0.06);
}

.drawer-action--danger {
  background: rgba(255, 106, 69, 0.1);
}

.drawer-action__text,
.drawer-cancel__text {
  font-size: 28rpx;
  font-weight: 500;
}

.drawer-action__text {
  color: #ffffff;
}

.drawer-action--danger .drawer-action__text {
  color: #ff6a45;
}

.drawer-cancel {
  margin-top: 14rpx;
  background: rgba(255, 255, 255, 0.03);
}

.drawer-cancel__text {
  color: rgba(255, 255, 255, 0.78);
}

.connect-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1300;
  padding: 32rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.68);
  display: flex;
  align-items: center;
  justify-content: center;
}

.connect-panel {
  width: 100%;
  max-width: 560rpx;
  padding: 44rpx 40rpx 36rpx;
  box-sizing: border-box;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(26, 26, 26, 0.98) 0%, rgba(12, 12, 12, 0.98) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 24rpx 72rpx rgba(0, 0, 0, 0.38);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.connect-spinner {
  width: 88rpx;
  height: 88rpx;
  box-sizing: border-box;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 106, 69, 0.18);
  border-top-color: #ff6a45;
  border-right-color: rgba(255, 77, 79, 0.92);
  animation: connect-spin 0.9s linear infinite;
}

.connect-title {
  margin-top: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.connect-device {
  margin-top: 10rpx;
  max-width: 100%;
  font-size: 26rpx;
  line-height: 1.6;
  color: #ffb7a4;
  word-break: break-all;
}

.connect-desc {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.7);
}

.connect-cancel {
  width: 100%;
  min-height: 84rpx;
  margin-top: 28rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.connect-cancel__text {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
}

@keyframes connect-spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 断开按钮 */
.disconnect-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: rgba(255, 68, 68, 0.2);
  border: 1px solid rgba(255, 68, 68, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.disconnect-btn:active {
  background-color: rgba(255, 68, 68, 0.3);
  transform: scale(0.9);
}

/* 微光效果 - 只作用于当前点击的卡片 */
.tab-item {
  position: relative;
  overflow: hidden;
}

.tab-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.5s ease;
  z-index: 1;
  pointer-events: none;
}

.tab-item:active::before {
  left: 100%;
}

/* 移除波纹效果 */
.tab-item::after {
  display: none;
}

/* 呼吸灯动画 */
@keyframes pulse {
  0% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.2);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}