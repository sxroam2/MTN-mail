<!-- pages/home/home.wxml -->
<view class="page">
  <view class="top">
    <view class="top-top">
      <view class="topleft-title">{{homeTitle}}　{{currentModel}}</view>
    </view>
    <view class="top-center">
      <image class="bg-image" src="/assets/BG.jpg" mode="aspectFill" />
      <swiper indicator-dots="{{true}}" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#ff6a45" autoplay="{{true}}" interval="{{3000}}" circular="{{true}}" bindchange="onSwiperChange" class="carousel-swiper">
        <swiper-item wx:for="{{carouselData}}" wx:key="index">
          <image class="carousel-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        </swiper-item>
      </swiper>
    </view>
  </view>

  <view class="bottom">
    <!-- 全部标签页 -->
    <van-tabs swipeable color="#ff6a45" title-active-color="#fff">
      <van-tab title="全部">
        <view class="tab">
          <!-- 设备列表区域 -->
          <view class="device-list-section">
            <!-- 添加设备按钮 -->
            <view class="tab-item add-device" bindtap="onAddDevice" hover-class="button-hover" hover-stay-time="200">
              <view class="tab-container">
                <image src="/assets/insertBtn.png" class="tab-image" mode="aspectFit" />
                <view class="tab-text">添加设备</view>
              </view>
            </view>

            <!-- 已连接设备列表 -->
            <view class="tab-item {{item.connected ? 'connected' : ''}}" 
                  wx:for="{{connectedDevices}}" 
                  wx:key="deviceId" 
                  bindtap="connectToDevice" 
                  bindlongpress="onLongPressDevice"
                  data-device="{{item}}" 
                  data-index="{{index}}" 
                  hover-class="button-hover" 
                  hover-stay-time="200">
              <view class="tab-container">
                <image src="{{item.image}}" class="tab-image" mode="aspectFit" />
                <view class="tab-text">{{item.displayName || item.name}}</view>
                <!-- 已连接状态标记 -->
                <view class="device-status" wx:if="{{item.connected}}">
                  <view class="status-dot"></view>
                  <text class="status-text">已连接</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </van-tab>
    </van-tabs>
  </view>

  <view wx:if="{{showActionSheet}}" class="drawer-mask" bindtap="onCloseActionSheet">
    <view class="drawer-panel" catchtap="noop">
      <view class="drawer-handle"></view>
      <view class="drawer-header">
        <text class="drawer-title">设备操作</text>
      </view>

      <view class="drawer-actions">
        <view
          wx:for="{{actionSheetActions}}"
          wx:key="name"
          class="drawer-action drawer-action--{{item.tone || 'default'}}"
          data-name="{{item.name}}"
          bindtap="onActionSheetActionTap"
        >
          <text class="drawer-action__text">{{item.name}}</text>
        </view>
      </view>

      <view class="drawer-cancel" bindtap="onCloseActionSheet">
        <text class="drawer-cancel__text">取消</text>
      </view>
    </view>
  </view>
</view>