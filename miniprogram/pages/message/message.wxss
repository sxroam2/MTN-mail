/* pages/message/message.wxss - 添加新样式 */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;  /* 防止整个页面滚动 */
}

/* 上半部分：仪表盘区域 - 固定高度 */
.gauge-section {
  height: 45vh;
  flex-shrink: 0;  /* 防止被压缩 */
}

/* 下半部分：参数区域 - 可滚动 */
.params-section {
  flex: 1;
  overflow-y: auto;  /* 允许纵向滚动 */
  -webkit-overflow-scrolling: touch;  /* iOS 平滑滚动 */
  padding: 20rpx 30rpx;
}

/* 保留原有的上半部分样式 */
.gauge-section {
  height: 45vh;
  display: flex;
  justify-content: center;
  align-items: center;
  border-bottom: 1px solid #333;
  margin-top: 0;
  padding-top: 0;
}

.gauge-container {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.gauge-swiper {
  width: 100%;
  height: 100%;
}

.mychart {
  width: 100%;
  height: 100%;
}

.gauge-label {
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  opacity: 0.7;
  z-index: 10;
  pointer-events: none;
}

.gauge-dots {
  position: absolute;
  bottom: 10rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 8rpx;
  z-index: 10;
}

.gauge-dots .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background-color: rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.gauge-dots .dot.active {
  width: 32rpx;
  background-color: #ff6a45;
}

/* 下半部分参数区域 */
.params-section {
  flex: 1;
  padding: 20rpx 30rpx 30rpx;
  overflow-y: auto;
}

.empty-hint {
  padding: 48rpx 0;
  text-align: center;
  color: #777;
  font-size: 26rpx;
}

/* 参数头部 - 品牌型号 */
.params-header {
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}

.device-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff6a45;
  letter-spacing: 1px;
}

/* 参数项卡片 */
.param-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
  background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  border: 1px solid #333;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.3);
  transition: all 0.2s ease;
}

.param-item:active {
  transform: scale(0.98);
  background: linear-gradient(145deg, #1a1a1a, #2a2a2a);
}

.param-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.param-label {
  font-size: 28rpx;
  color: #fff;
}

.param-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #ff6a45;
}

/* 各节电池电压区域 */
.cell-voltage-section {
  background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1px solid #333;
}

.cell-voltage-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.cell-voltage-grid {
  display: grid;
  gap: 16rpx;
}

.cell-voltage-item {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 16rpx 0;
  text-align: center;
  border: 1px solid #333;
}

.cell-number {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.cell-voltage-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff6a45;
}

/* 固定参数区域 */
.fixed-params {
  margin-top: 20rpx;
  border-top: 1px solid #333;
  padding-top: 16rpx;
}

/* 状态样式 */
.status-text.idle {
  color: #4cd964;
}

.status-text.charging {
  color: #FFA500;
}

.status-text.error {
  color: #fd666d;
}

.fault-text {
  color: #fd666d !important;
}

.param-value.fault {
  color: #fd666d;
}

.param-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

/* 其他样式保持不变 */
.param-left {
  display: flex;
  align-items: center;
}

.param-label {
  font-size: 28rpx;
  color: #fff;
}

.param-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff6a45;
}

.van-notice-bar{
  height: 2.5vh !important;
}