/* 覆盖全局 page 固定定位，恢复原生滚动 */
page {
  position: static !important;
  height: auto !important;
  overflow-y: auto !important;
}

/* 商品详情页 - 深色风格 */
.detail-page {
  min-height: 100vh;
  background: #000;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* 吸顶导航栏 */
.sticky-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #0a0a0a;
  border-bottom: 1rpx solid #222;
  opacity: 0;
  pointer-events: none;
  transform: translateY(-100%);
  transition: transform 0.25s ease, opacity 0.25s ease;
}
.sticky-nav.visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}
.sticky-nav-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  font-size: 28rpx;
  color: #999;
  height: 88rpx;
}
.sticky-nav-item.active {
  color: #ff6a45;
  font-weight: 600;
}
.nav-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #ff6a45;
  border-radius: 2rpx;
}

.detail-goods-action {
  --goods-action-background-color: rgba(10, 10, 10, 0.9);
  --goods-action-icon-color: #bbb;
  --goods-action-icon-text-color: #bbb;
  --button-default-background-color: var(--goods-action-background-color);
  --button-default-border-color: transparent;
  --button-default-color: #bbb;
  border-top: 1rpx solid #222;
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  box-shadow: 0 -12rpx 30rpx rgba(255, 106, 69, 0.08);
}

.page-loading {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  text-align: center;
  background: #000;
  z-index: 10;
}

/* 轮播图 */
.swiper-wrap {
  position: relative;
}
.image-swiper {
  width: 100%;
  height: 600rpx;
  background: #1a1a1a;
}
.product-image {
  width: 100%;
  height: 100%;
}
.swiper-counter {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  z-index: 10;
}

/* 价格区域 */
.price-section {
  padding: 30rpx;
  background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
}
.price-header {
  display: flex;
  align-items: stretch;
  gap: 24rpx;
}
.price-info {
  flex: 1;
  min-width: 0;
}
.price-main {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}
.currency {
  font-size: 28rpx;
  color: #ff6a45;
  font-weight: bold;
}
.price-value {
  font-size: 48rpx;
  color: #ff6a45;
  font-weight: bold;
}
.original-price {
  font-size: 24rpx;
  color: #666;
  text-decoration: line-through;
  margin-left: 16rpx;
}
.product-name-row {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
}
.product-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  line-height: 1.5;
  flex: 1;
}
.share-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  min-width: 96rpx;
  padding: 0;
  flex-shrink: 0;
  background: transparent;
  border: none;
  color: inherit;
  line-height: normal;
  text-align: center;
}
.share-btn::after {
  border: none;
}
.share-text {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 通用卡片 */
.section-card {
  margin: 20rpx 24rpx;
  padding: 30rpx;
  background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
  border-radius: 12rpx;
}
.section-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 20rpx;
}

/* 已选规格入口 */
.spec-entry {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
}
.spec-entry .spec-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.spec-entry .spec-value {
  font-size: 26rpx;
  color: #fff;
  flex: 1;
}

/* 配送信息 */
.delivery-card {
  padding: 24rpx 30rpx;
}
.delivery-row {
  display: flex;
  align-items: center;
}
.delivery-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.delivery-value {
  font-size: 26rpx;
  color: #ccc;
  flex: 1;
}
.delivery-value.selected {
  color: #fff;
}
.delivery-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}
.delivery-link {
  font-size: 26rpx;
  color: #999;
}

/* 服务说明 */
.service-card {
  padding: 24rpx 30rpx;
}
.service-row {
  display: flex;
  align-items: center;
}
.service-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.service-value {
  font-size: 26rpx;
  color: #ccc;
  flex: 1;
}
.service-arrow {
  flex-shrink: 0;
}

/* 参数表 */
.spec-table {
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}
.spec-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}
.spec-label-cell {
  width: 200rpx;
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}
.spec-value-cell {
  font-size: 24rpx;
  color: #ccc;
  flex: 1;
}

/* 参数分组标题 */
.spec-group-name {
  font-size: 26rpx;
  color: #ff6a45;
  font-weight: 500;
  padding: 20rpx 0 8rpx;
}

/* 多套餐对比表格 */
.compare-table {
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  overflow: hidden;
}
.compare-header {
  display: flex;
  background: #2a2a2a;
}
.compare-header-cell {
  font-weight: 600;
  color: #fff !important;
  font-size: 24rpx;
}
.compare-group-row {
  font-size: 24rpx;
  color: #ff6a45;
  font-weight: 500;
  padding: 16rpx 20rpx;
  background: rgba(255, 106, 69, 0.08);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}
.compare-row {
  display: flex;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}
.compare-row:last-child {
  border-bottom: none;
}
.compare-key-cell {
  width: 180rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.02);
}
.compare-val-cell {
  flex: 1;
  padding: 16rpx 16rpx;
  font-size: 24rpx;
  color: #ccc;
  text-align: center;
}

/* ============ 规格选择抽屉（已迁移至 sku-drawer 组件） ============ */

/* ============ 服务说明抽屉 ============ */
.service-drawer {
  padding: 48rpx 40rpx calc(env(safe-area-inset-bottom) + 32rpx);
}
.service-drawer-section {
  margin-bottom: 40rpx;
}
.service-drawer-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.service-drawer-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.7;
}
.service-drawer-btn {
  margin-top: 40rpx;
}

/* ============ 商品详情内容 ============ */
.detail-content {
  padding-top: 8rpx;
}
.detail-text {
  font-size: 26rpx;
  color: #ccc;
  line-height: 1.7;
  margin-bottom: 16rpx;
}
.detail-img {
  width: 100%;
  display: block;
}

/* 参数区域最小高度（确保吸顶导航点击可滚动到位） */
#section-specs {
  min-height: calc(100vh - 88rpx);
  box-sizing: border-box;
}


