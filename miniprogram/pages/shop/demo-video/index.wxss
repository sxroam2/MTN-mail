.page {
  min-height: 100vh;
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
}

.tools-panel {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding-top: 30rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 84rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 14rpx 36rpx rgba(0, 0, 0, 0.16);
}

.search-input {
  flex: 1;
  height: 84rpx;
  margin-left: 16rpx;
  color: #ffffff;
  font-size: 24rpx;
}

.search-placeholder {
  color: #6d7177;
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.layout-icon-btn {
  flex-shrink: 0;
  width: 84rpx;
  height: 84rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 36rpx rgba(0, 0, 0, 0.16);
}

.layout-icon-btn-double,
.layout-icon-btn-single {
  border-color: rgba(255, 106, 69, 0.18);
}

.tab-scroll {
  width: 100%;
  margin-top: 2rpx;
  white-space: nowrap;
}

.tab-list {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  padding-right: 12rpx;
  padding-bottom: 22rpx;
}

.tab-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 26rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  color: #8f9399;
  font-size: 24rpx;
  transition: all 0.2s;
}

.tab-pill.active {
  background: linear-gradient(90deg, #ff6a45 0%, #ff4d4f 100%);
  border-color: transparent;
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 12rpx 28rpx rgba(255, 106, 69, 0.24);
}

/* ── 加载 / 空状态 ── */
.page-loading,
.empty-state {
  min-height: 640rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-title {
  margin-top: 22rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-desc {
  margin-top: 12rpx;
  color: #666666;
  font-size: 24rpx;
}

/* ── 视频网格 ── */
.video-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.video-card {
  width: calc((100% - 16rpx) / 2);
  margin-bottom: 18rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.03) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.24);
}

.single-mode .video-card {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  border-radius: 30rpx;
}

.video-card-hover {
  transform: translateY(-4rpx);
  border-color: rgba(255, 106, 69, 0.14);
}

/* ── 封面区域 (16:9) ── */
.card-cover-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: #0f0f10;
}

.single-mode .card-cover-wrap {
  width: 310rpx;
  flex-shrink: 0;
  aspect-ratio: unset;
  height: auto;
  min-height: 188rpx;
}

.card-cover {
  width: 100%;
  height: 100%;
}

.card-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-gradient {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 55%;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.64) 100%);
}

/* 居中播放按钮 */
.card-play-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(8, 8, 8, 0.5);
}

.single-mode .card-play-center {
  width: 64rpx;
  height: 64rpx;
}

.card-duration {
  position: absolute;
  right: 14rpx;
  bottom: 12rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(8, 8, 8, 0.56);
  color: #ffffff;
  font-size: 20rpx;
}

.card-body {
  padding: 20rpx 20rpx 22rpx;
}

.single-mode .card-body {
  flex: 1;
  min-width: 0;
  padding: 22rpx 22rpx 22rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card-title {
  display: -webkit-box;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.42;
  font-weight: 600;
  line-clamp: 2;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.single-mode .card-title {
  font-size: 30rpx;
  line-clamp: 2;
  -webkit-line-clamp: 2;
}

.card-desc {
  display: -webkit-box;
  margin-top: 12rpx;
  color: #9ea4ab;
  font-size: 23rpx;
  line-height: 1.7;
  text-overflow: ellipsis;
  line-clamp: 2;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
