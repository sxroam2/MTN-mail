.detail-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(255, 106, 69, 0.12), transparent 26%),
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.04), transparent 20%),
    linear-gradient(180deg, #060606 0%, #020202 100%);
  box-sizing: border-box;
}

/* ── 加载 / 整页空状态 ── */
.page-loading,
.video-empty-page {
  min-height: 860rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 48rpx;
  box-sizing: border-box;
}

/* ── 播放器 (全宽无圆角，沉浸感) ── */
.player-shell {
  width: auto;
  margin: 16rpx 24rpx 0;
  overflow: hidden;
  background: #090909;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.22);
}

.video-wrap {
  width: 100%;
  background: #000000;
}

.video-player {
  width: 100%;
  height: 436rpx;
  background: #000000;
  display: block;
}

/* 无地址时的占位 */
.video-empty {
  min-height: 424rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.empty-title {
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-desc {
  margin-top: 12rpx;
  color: #666666;
  font-size: 22rpx;
  line-height: 1.6;
}

/* ── 信息卡 ── */
.info-card {
  margin: 20rpx 24rpx 0;
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.16);
}

.video-title {
  display: block;
  color: #ffffff;
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 700;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 106, 69, 0.16);
  color: #ffb096;
  font-size: 22rpx;
}

.video-desc {
  display: block;
  margin-top: 20rpx;
  color: #a7acb2;
  font-size: 24rpx;
  line-height: 1.85;
}

.section-card {
  margin: 18rpx 24rpx 40rpx;
  padding: 28rpx 22rpx 22rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.045);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.16);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx 14rpx;
  margin-bottom: 8rpx;
}

.section-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.section-subtitle {
  color: #7f858b;
  font-size: 22rpx;
}

.related-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.related-item {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  padding: 14rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.045) 0%, rgba(255, 255, 255, 0.028) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.related-item-hover {
  background: rgba(255, 106, 69, 0.08);
  border-color: rgba(255, 106, 69, 0.14);
}

.related-thumb-wrap {
  position: relative;
  flex-shrink: 0;
  width: 208rpx;
  height: 132rpx;
  overflow: hidden;
  border-radius: 18rpx;
  background: #151515;
}

.related-thumb {
  width: 100%;
  height: 100%;
  background: #1a1a1a;
}

.related-thumb-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.related-thumb-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 56%;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.52) 100%);
}

.related-thumb-play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.42);
}

.related-duration {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.56);
  color: #ffffff;
  font-size: 18rpx;
}

.related-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.related-title {
  display: -webkit-box;
  color: #f2f3f5;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 600;
  line-clamp: 2;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.related-desc {
  display: block;
  margin-top: 10rpx;
  color: #99a0a8;
  font-size: 22rpx;
  line-height: 1.65;
  display: -webkit-box;
  line-clamp: 2;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── 按钮 ── */
.empty-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.ghost-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #cccccc;
  background: transparent;
  border: 1rpx solid #333333;
}

.primary-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(90deg, #ff6a45 0%, #ff4d4f 100%);
  border: none;
}
