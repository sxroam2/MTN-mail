.page {
  min-height: 100vh;
  background: #000;
  padding-bottom: calc(env(safe-area-inset-bottom) + 124rpx);
}

.page-loading {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  text-align: center;
  background: #000;
  z-index: 10;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 240rpx;
  gap: 24rpx;
}

.empty-text {
  color: #666;
  font-size: 28rpx;
}

.auth-wrap {
  padding-left: 64rpx;
  padding-right: 64rpx;
}

.auth-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.auth-desc {
  color: #8c8c8c;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: center;
}

/* 顶部栏 — 毛玻璃 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(26, 26, 26, 0.8);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  border-bottom: 1rpx solid #222;
}
.top-address {
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 60%;
  min-width: 0;
}
.top-address-text {
  font-size: 26rpx;
  color: #ccc;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}
.top-edit-btn {
  flex-shrink: 0;
  padding: 8rpx 20rpx;
}
.top-edit-text {
  font-size: 26rpx;
  color: #ff6a45;
}

.top-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.top-clean-btn {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 106, 69, 0.45);
  color: #ff8d68;
  font-size: 24rpx;
}

/* 购物车列表项 — 无分割线 */
.cart-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.cart-item--invalid {
  opacity: 0.62;
}
.cart-item + .cart-item {
  margin-top: 8rpx;
}

.item-checkbox {
  margin-right: 16rpx;
}

.item-content {
  display: flex;
  flex: 1;
  gap: 20rpx;
  align-items: flex-start;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 160rpx;
  justify-content: space-between;
}

.item-name {
  font-size: 28rpx;
  color: #fff;
  display: -webkit-box;
  line-clamp: 2;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.invalid-tag {
  align-self: flex-start;
  margin-top: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 77, 79, 0.12);
  color: #ff9b9b;
  font-size: 22rpx;
}

.item-spec {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 8rpx;
  background: #2a2a2a;
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
  align-self: flex-start;
}
.item-spec-text {
  font-size: 22rpx;
  color: #888;
}

.item-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6f6f6f;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.item-price {
  font-size: 30rpx;
  color: #ff6a45;
  font-weight: bold;
}

.item-original-price {
  font-size: 24rpx;
  color: #888;
  text-decoration: line-through;
  margin-left: 8rpx;
}

/* 方形数量选择器 */
.qty-stepper {
  display: inline-flex;
  align-items: center;
  border-radius: 8rpx;
  overflow: hidden;
  outline: 1rpx solid rgba(89, 65, 59, 0.15);
}
.qty-btn {
  width: 52rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
  background: #2a2a2a;
}
.qty-btn:active {
  background: rgba(255, 106, 69, 0.2);
}
.qty-btn.disabled {
  color: #555;
  background: #1a1a1a;
}
.qty-value {
  min-width: 56rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  background: #1a1a1a;
  border-left: 1rpx solid rgba(89, 65, 59, 0.15);
  border-right: 1rpx solid rgba(89, 65, 59, 0.15);
}

/* 底部栏 */
.bottom-dock {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 10rpx 24rpx calc(env(safe-area-inset-bottom) + 10rpx);
  z-index: 20;
  background: transparent;
}

.bottom-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 18rpx 0 20rpx;
  background: rgba(26, 26, 26, 0.8);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  box-sizing: border-box;
}

.check-all {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.check-all-text {
  font-size: 26rpx;
  color: #ccc;
}

.bar-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.total-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  min-width: 0;
  justify-content: flex-end;
  flex-wrap: wrap;
}

.total-label {
  font-size: 26rpx;
  color: #aaa;
}

.total-original-price {
  font-size: 24rpx;
  color: #888;
  text-decoration: line-through;
}

.total-price {
  font-size: 34rpx;
  color: #ff6a45;
  font-weight: bold;
}

.bar-btn {
  min-width: 176rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
}

.bar-btn-text {
  display: block;
  width: 100%;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.checkout-btn {
  background: linear-gradient(90deg, #ff6a45 0%, #ff4d4f 100%);
}

.delete-btn {
  background: linear-gradient(90deg, #ff6a45 0%, #ff4d4f 100%);
}

.bar-btn.is-disabled {
  opacity: 0.45;
}


