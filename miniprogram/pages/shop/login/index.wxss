.page {
  min-height: 100vh;
  background: #000;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  margin-bottom: 80rpx;
}

.brand-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.brand-name {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.brand-slogan {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
  letter-spacing: 8rpx;
}

.login-form {
  width: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.form-group {
  background: #1a1a1a !important;
  border-radius: 24rpx !important;
  overflow: hidden;
}

.login-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  flex-wrap: wrap;
}

.tip-text {
  font-size: 22rpx;
  color: #666;
}

.tip-link {
  font-size: 22rpx;
  color: #ff6a45;
}
