<!-- 退款详情页 -->
<view class="page">
  <van-loading wx:if="{{ loading }}" size="36px" color="#ff6a45" vertical class="page-loading">加载中...</van-loading>

  <block wx:elif="{{ refund }}">
    <!-- 退款状态 -->
    <view class="status-banner status-{{ refund.status }}">
      <van-icon name="{{ statusIcon }}" size="36px" color="#fff" />
      <view class="status-info">
        <text class="status-title">{{ statusText }}</text>
        <text class="status-desc">{{ statusDesc }}</text>
      </view>
    </view>

    <!-- 退款金额 -->
    <view class="section-card">
      <view class="info-row">
        <text class="info-label">退款金额</text>
        <text class="info-value amount">¥{{ refund.refundAmount }}</text>
      </view>
      <view class="info-row">
        <text class="info-label">退款类型</text>
        <text class="info-value">{{ refund.refundType === 2 ? '退货退款' : '仅退款' }}</text>
      </view>
      <view class="info-row">
        <text class="info-label">退款原因</text>
        <text class="info-value">{{ refund.reason }}</text>
      </view>
      <view wx:if="{{ refund.description }}" class="info-row">
        <text class="info-label">退款说明</text>
        <text class="info-value">{{ refund.description }}</text>
      </view>
    </view>

    <!-- 凭证图片 -->
    <view wx:if="{{ refund.images && refund.images.length > 0 }}" class="section-card">
      <view class="section-title">凭证图片</view>
      <view class="image-list">
        <van-image
          wx:for="{{ refund.images }}"
          wx:key="index"
          width="160rpx"
          height="160rpx"
          src="{{ item }}"
          fit="cover"
          radius="8rpx"
          bindtap="previewImage"
          data-index="{{ index }}"
        />
      </view>
    </view>

    <!-- 退款进度时间线 -->
    <view wx:if="{{ timeline.length > 0 }}" class="section-card">
      <view class="section-title">退款进度</view>
      <view class="timeline-list">
        <view
          wx:for="{{ timeline }}"
          wx:key="index"
          class="timeline-item {{ index === 0 ? 'active' : '' }}"
        >
          <view class="tl-dot {{ index === 0 ? 'dot-active' : '' }}"></view>
          <view wx:if="{{ index < timeline.length - 1 }}" class="tl-line"></view>
          <view class="tl-content">
            <text class="tl-text">{{ item.content }}</text>
            <text class="tl-time">{{ item.time }}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 订单号 -->
    <view class="section-card">
      <view class="info-row">
        <text class="info-label">订单编号</text>
        <text class="info-value">{{ refund.orderNo }}</text>
      </view>
      <view class="info-row">
        <text class="info-label">申请时间</text>
        <text class="info-value">{{ refund.createTime }}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view wx:if="{{ refund.status === 0 }}" class="action-wrap">
      <van-button plain round color="#999" bindtap="cancelRefund">撤销申请</van-button>
    </view>
  </block>
</view>
