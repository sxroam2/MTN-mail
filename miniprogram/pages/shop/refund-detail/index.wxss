/* 退款详情页 - 深色风格 */
.page {
  min-height: 100vh;
  background: #000;
}

.page-loading {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  text-align: center;
  background: #000;
  z-index: 10;
}

/* 状态栏 */
.status-banner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #ff6a45, #ff4d4f);
}

.status-banner.status-2 {
  background: linear-gradient(135deg, #999, #777);
}

.status-banner.status-3 {
  background: linear-gradient(135deg, #52c41a, #389e0d);
}

.status-banner.status-4 {
  background: linear-gradient(135deg, #999, #777);
}

.status-info {
  display: flex;
  flex-direction: column;
}

.status-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

/* 通用卡片 */
.section-card {
  margin: 2rpx 0;
  padding: 30rpx;
  background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
}

.section-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #ccc;
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
}

.info-value.amount {
  color: #ff4d4f;
  font-weight: bold;
  font-size: 30rpx;
}

/* 图片列表 */
.image-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

/* 时间线 */
.timeline-list {
  padding-left: 8rpx;
}

.timeline-item {
  display: flex;
  position: relative;
  min-height: 80rpx;
}

.tl-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #444;
  flex-shrink: 0;
  margin-top: 8rpx;
  z-index: 1;
}

.dot-active {
  background: #ff6a45;
  width: 20rpx;
  height: 20rpx;
}

.tl-line {
  position: absolute;
  left: 7rpx;
  top: 28rpx;
  width: 2rpx;
  bottom: 0;
  background: #333;
}

.tl-content {
  flex: 1;
  padding-left: 20rpx;
  padding-bottom: 24rpx;
}

.tl-text {
  font-size: 26rpx;
  color: #fff;
  line-height: 1.4;
}

.timeline-item:not(.active) .tl-text {
  color: #999;
}

.tl-time {
  font-size: 22rpx;
  color: #666;
  margin-top: 6rpx;
  display: block;
}

/* 操作 */
.action-wrap {
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: center;
}
