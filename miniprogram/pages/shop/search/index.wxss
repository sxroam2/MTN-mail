/* 搜索页 - 深色风格 */
page {
  position: static !important;
  height: auto !important;
  overflow-y: auto !important;
}

.page {
  min-height: 100vh;
  background: #000;
}

.page-loading {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  text-align: center;
  background: #000;
  z-index: 10;
}

/* van-search 深色覆盖 */
.page van-search {
  --search-background-color: #1a1a1a;
  --search-input-text-color: #fff;
  --search-placeholder-text-color: #666;
}

/* 区块 */
.section {
  margin: 16rpx 24rpx 0;
  padding: 28rpx;
  background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
  border-radius: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 26rpx;
  color: #aaa;
  font-weight: 500;
}

/* 搜索历史标签 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  color: #ccc;
  background: rgba(255, 255, 255, 0.07);
  border-radius: 28rpx;
}

/* 热门搜索 - 2列卡片网格 */
.hot-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.hot-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  overflow: hidden;
}

.hot-rank {
  width: 38rpx;
  height: 38rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #666;
  background: rgba(255, 255, 255, 0.06);
  flex-shrink: 0;
}

.hot-rank-top {
  color: #fff;
  background: linear-gradient(135deg, #ff6a45, #ff4d4f);
}

.hot-word {
  flex: 1;
  font-size: 26rpx;
  color: #ccc;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 搜索结果 */
.product-list {
  padding: 0 20rpx 20rpx;
}

.product-card {
  display: flex;
  padding: 24rpx 0;
  position: relative;
}

.product-card + .product-card {
  margin-top: 8rpx;
}

.card-hover {
  background: #1a1a1a;
}

.card-img-wrap {
  position: relative;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.soldout-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.45);
}

.soldout-text {
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.tag {
  display: inline-block;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  line-height: 1.5;
}

.tag-new {
  border: 1rpx solid rgba(255, 106, 69, 0.3);
  background: rgba(255, 106, 69, 0.15);
  color: #ff6a45;
}

.tag-flash {
  border: 1rpx solid rgba(255, 77, 79, 0.3);
  background: rgba(255, 77, 79, 0.15);
  color: #ff4d4f;
}

.card-info {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 220rpx;
}

.card-title {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.4;
  display: -webkit-box;
  line-clamp: 2;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-bottom {
  margin-top: auto;
}

.card-price-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.card-price {
  font-size: 34rpx;
  color: #ff6a45;
  font-weight: bold;
}

.card-original-price {
  font-size: 22rpx;
  color: #666;
  text-decoration: line-through;
}

.card-cart-btn {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 106, 69, 0.4);
  border-radius: 50%;
  background: rgba(255, 106, 69, 0.1);
}

.card-cart-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  margin-top: 20rpx;
}
