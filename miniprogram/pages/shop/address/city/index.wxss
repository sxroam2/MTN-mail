page {
  background: #000000;
}

.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(255, 106, 69, 0.18), transparent 34%),
    linear-gradient(180deg, #050505 0%, #0e0e0e 38%, #151515 100%);
}

.top-shell {
  position: sticky;
  top: 0;
  z-index: 20;
  padding: 20rpx 24rpx 12rpx;
  padding-top: calc(18rpx + env(safe-area-inset-top));
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.96), rgba(0, 0, 0, 0.86));
  backdrop-filter: blur(20px);
}

.page-scroll {
  height: calc(100vh - 112rpx - env(safe-area-inset-top));
}

.panel {
  margin: 0 24rpx 18rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(20, 20, 20, 0.94);
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.28);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.panel-list {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.index-scroll {
  width: 100%;
  white-space: nowrap;
}

.index-row {
  display: inline-flex;
  gap: 14rpx;
}

.index-pill {
  min-width: 60rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  text-align: center;
  font-size: 24rpx;
  color: #d8d8d8;
  background: #1d1d1d;
  box-sizing: border-box;
}

.index-pill-active {
  color: #ffffff;
  background: linear-gradient(90deg, #ff6a45 0%, #ff4d4f 100%);
}

.panel-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 24rpx;
  color: #8f8f8f;
  letter-spacing: 2rpx;
}

.current-city-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(255, 106, 69, 0.18), rgba(255, 77, 79, 0.08));
}

.current-city-badge {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 106, 69, 0.18);
}

.current-city-badge-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #ff6a45 0%, #ff4d4f 100%);
  box-shadow: 0 0 18rpx rgba(255, 106, 69, 0.45);
}

.current-city-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.current-city-name {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 600;
}

.current-city-desc {
  font-size: 22rpx;
  color: #c0c0c0;
}

.hot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-pill {
  min-width: calc((100% - 32rpx) / 3);
  padding: 22rpx 12rpx;
  border-radius: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #e7e7e7;
  background: #1d1d1d;
  box-sizing: border-box;
}

.hot-pill-active {
  color: #ffffff;
  background: linear-gradient(90deg, #ff6a45 0%, #ff4d4f 100%);
}

.group-body {
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.02);
}

.city-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 20rpx;
}

.city-row + .city-row {
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.city-row-active {
  background: rgba(255, 106, 69, 0.12);
}

.city-name {
  font-size: 28rpx;
  color: #ffffff;
}

.city-province {
  font-size: 22rpx;
  color: #7d7d7d;
}

.empty-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 90rpx 0 80rpx;
}

.empty-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #888888;
}