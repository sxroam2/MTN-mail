page {
  position: static !important;
  height: auto !important;
  overflow-y: auto !important;
  background: #000000;
}

.page {
  position: relative;
  min-height: 100vh;
  height: 100vh;
  overflow: hidden;
  background: #000000;
}

.page-loading {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  background: #000000;
}

/* 顶部地图 */
.top-map {
  width: 100%;
  height: 420rpx;
  display: block;
}

.form-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 15;
  padding-top: 16rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: rgba(26, 26, 26, 0.96);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  box-shadow: 0 -12rpx 30rpx rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  transition: height 180ms ease;
}

.form-sheet-drag-zone {
  flex-shrink: 0;
  padding-bottom: 8rpx;
}

.form-sheet-handle {
  width: 96rpx;
  height: 8rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.form-sheet-scroll {
  flex: 1;
  min-height: 0;
  padding: 0 24rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 收货信息卡片 */
.info-card {
  margin: 0 0 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
  outline: 1rpx solid rgba(89, 65, 59, 0.15);
}

.info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.info-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #ffffff;
}

.info-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.action-link {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #cccccc;
}

.action-link.wechat {
  color: #07c160;
}

.action-link-busy {
  opacity: 0.6;
}

/* 单行字段 */
.row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 96rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.row.row-last {
  border-bottom: none;
}

.row.row-address {
  align-items: flex-start;
}

.row-label {
  width: 150rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #ffffff;
}

.row-address .row-label {
  padding-top: 18rpx;
}

.row-value {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.row-value.row-value-address {
  align-items: flex-start;
}

.row-input {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  font-size: 28rpx;
  color: #ffffff;
}

.row-textarea {
  flex: 1;
  min-width: 0;
  min-height: 120rpx;
  max-height: 240rpx;
  padding: 6rpx 0;
  font-size: 28rpx;
  line-height: 1.5;
  color: #ffffff;
  box-sizing: border-box;
}

.row-text {
  flex: 1;
  font-size: 28rpx;
  color: #ffffff;
}

.row-placeholder {
  color: #666666;
}

.row-arrow {
  font-size: 36rpx;
  line-height: 1;
  color: #888888;
}

.row-locate {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #ff6a45;
  background: rgba(255, 106, 69, 0.1);
  font-size: 24rpx;
}

.row-value-address .row-locate {
  margin-top: 6rpx;
}

.locate-icon {
  width: 26rpx;
  height: 26rpx;
  display: block;
}

.locate-text {
  font-size: 24rpx;
  line-height: 1;
}

/* 地址标签卡片 */
.label-card {
  margin: 0 0 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
  outline: 1rpx solid rgba(89, 65, 59, 0.15);
}

.label-title {
  display: block;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #ffffff;
}

.label-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.label-pill {
  min-width: 110rpx;
  height: 64rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #cccccc;
  background: rgba(255, 255, 255, 0.06);
}

.label-pill-active {
  color: #ffffff;
  background: linear-gradient(90deg, rgba(255, 106, 69, 0.9), rgba(255, 77, 79, 0.9));
}

/* 默认地址卡片 */
.default-card {
  margin: 0 0 24rpx;
  padding: 6rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
  outline: 1rpx solid rgba(89, 65, 59, 0.15);
}

.default-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 100rpx;
}

.default-switch-wrap {
  position: relative;
  z-index: 1;
}

.default-text {
  font-size: 28rpx;
  color: #ffffff;
}

/* 底栏 */
.footer-space {
  height: 24rpx;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(10, 10, 10, 0.9);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
}
