<view class="page">
  <van-loading wx:if="{{ loading }}" size="36px" color="#ff6a45" vertical class="page-loading">加载中...</van-loading>

  <block wx:else>
    <map
      id="addressPreviewMap"
      class="top-map"
      latitude="{{ locationInfo.latitude }}"
      longitude="{{ locationInfo.longitude }}"
      scale="16"
      markers="{{ markers }}"
      bindtap="openLocationPicker"
    ></map>

    <view class="form-sheet" style="height: {{ formSheetHeightPx }}px;">
      <view class="form-sheet-drag-zone" catchtouchstart="onFormSheetDragStart" catchtouchmove="onFormSheetDragMove" catchtouchend="onFormSheetDragEnd" catchtouchcancel="onFormSheetDragEnd">
        <view class="form-sheet-handle"></view>
      </view>

      <scroll-view scroll-y class="form-sheet-scroll">
        <view class="info-card">
          <view class="info-header">
            <text class="info-title">收货信息</text>
            <view class="info-actions">
              <view class="action-link wechat" bindtap="chooseWechatAddress">
                <text>微信导入</text>
              </view>
              <view class="action-link {{ parsingClipboard ? 'action-link-busy' : '' }}" bindtap="importFromClipboard">
                <text>{{ parsingClipboard ? '识别中…' : '粘贴地址' }}</text>
              </view>
            </view>
          </view>

          <picker mode="region" value="{{ regionValue }}" bindchange="onRegionChange">
            <view class="row">
              <text class="row-label">所在地区</text>
              <view class="row-value">
                <text class="row-text {{ regionLabel ? '' : 'row-placeholder' }}">{{ regionLabel || '选择省 / 市 / 区' }}</text>
                <text class="row-arrow">›</text>
              </view>
            </view>
          </picker>

          <view class="row row-address">
            <text class="row-label">详细地址</text>
            <view class="row-value row-value-address">
              <textarea class="row-textarea" auto-height maxlength="200" placeholder="请填写详细地址" placeholder-class="row-placeholder" value="{{ form.street }}" data-field="street" bindinput="onFieldInput" bindblur="onAddressBlur"></textarea>
              <view class="row-locate" catchtap="openLocationPicker">
                <image class="locate-icon" src="/assets/icons/location-pin.svg" mode="aspectFit" />
                <text class="locate-text">定位</text>
              </view>
            </view>
          </view>

          <view class="row">
            <text class="row-label">收货人</text>
            <view class="row-value">
              <input class="row-input" placeholder="收货人姓名" placeholder-class="row-placeholder" value="{{ form.receiverName }}" data-field="receiverName" bindinput="onFieldInput" />
            </view>
          </view>

          <view class="row row-last">
            <text class="row-label">手机号码</text>
            <view class="row-value">
              <input class="row-input" type="number" maxlength="11" placeholder="收货人手机号" placeholder-class="row-placeholder" value="{{ form.receiverPhone }}" data-field="receiverPhone" bindinput="onFieldInput" />
            </view>
          </view>
        </view>

        <view class="label-card">
          <text class="label-title">地址标签</text>
          <view class="label-list">
            <view wx:for="{{ labelOptions }}" wx:key="*this" class="label-pill {{ form.label === item ? 'label-pill-active' : '' }}" bindtap="selectLabel" data-label="{{ item }}">{{ item }}</view>
          </view>
        </view>

        <view class="default-card">
          <view class="default-row" bindtap="toggleDefault">
            <text class="default-text">设为默认收货地址</text>
            <view class="default-switch-wrap" catchtap="noop">
              <van-switch checked="{{ form.isDefault }}" active-color="#ff6a45" bind:change="onDefaultChange" />
            </view>
          </view>
        </view>

        <view class="footer-space"></view>
      </scroll-view>
    </view>

    <view class="footer-bar">
      <van-button round block color="linear-gradient(90deg, #ff6a45, #ff4d4f)" loading="{{ saving }}" bindtap="saveAddress">保存并使用</van-button>
    </view>
  </block>
</view>