page {
  background: #000000;
}

.page {
  position: relative;
  min-height: 100vh;
  background: #000000;
}

.picker-map {
  width: 100%;
  height: 100vh;
}

/* 顶部搜索栏 */
.top-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 24rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0));
}

.search-bar {
  display: flex;
  align-items: center;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(26, 26, 26, 0.92);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  outline: 1rpx solid rgba(89, 65, 59, 0.18);
}

.search-region {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding-right: 18rpx;
  flex-shrink: 0;
}

.region-text {
  font-size: 28rpx;
  color: #ffffff;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.region-arrow {
  width: 12rpx;
  height: 12rpx;
  margin-top: -8rpx;
  border-right: 3rpx solid #aaaaaa;
  border-bottom: 3rpx solid #aaaaaa;
  transform: rotate(45deg);
  flex-shrink: 0;
}

.search-divider {
  width: 1rpx;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.12);
}

.search-input {
  flex: 1;
  height: 84rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  color: #ffffff;
}

.search-placeholder {
  color: #777777;
}

/* 中央定位指针 */
.center-pin {
  position: fixed;
  left: 50%;
  top: 38%;
  z-index: 8;
  transform: translate(-50%, -100%);
  pointer-events: none;
}

.pin-dot {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #ff6a45 0%, #ff4d4f 100%);
  border: 6rpx solid rgba(255, 255, 255, 0.18);
  box-shadow: 0 16rpx 30rpx rgba(255, 106, 69, 0.3);
}

.pin-shadow {
  width: 28rpx;
  height: 10rpx;
  margin: 8rpx auto 0;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.3);
}

/* 定位按钮 */
.locate-fab {
  position: fixed;
  right: 28rpx;
  z-index: 9;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(26, 26, 26, 0.92);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.4);
  transition: bottom 180ms ease;
}

.locate-fab-icon {
  font-size: 38rpx;
  color: #ff6a45;
  line-height: 1;
}

/* 底部抽屉 */
.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 16rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: rgba(26, 26, 26, 0.96);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  box-shadow: 0 -12rpx 30rpx rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  transition: height 180ms ease;
}

.sheet-drag-zone {
  flex-shrink: 0;
  cursor: grab;
}

.sheet-handle {
  width: 96rpx;
  height: 8rpx;
  margin: 0 auto 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.sheet-title-row {
  padding: 6rpx 8rpx 14rpx;
}

.sheet-title {
  font-size: 28rpx;
  color: #cccccc;
}

.service-banner {
  margin: 0 8rpx 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(255, 106, 69, 0.14), rgba(255, 77, 79, 0.06));
  border: 1rpx solid rgba(255, 106, 69, 0.16);
}

.service-title {
  display: block;
  font-size: 24rpx;
  color: #ffd8cf;
}

.service-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #ffb4a4;
}

.poi-scroll {
  flex: 1;
  min-height: 0;
}

.empty-poi {
  padding: 40rpx 0 48rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

.poi-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 22rpx 8rpx;
}

.poi-icon {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  margin-top: 4rpx;
}

.locate-icon {
  width: 26rpx;
  height: 26rpx;
  display: block;
}

.poi-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.poi-name {
  font-size: 28rpx;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poi-name-active {
  color: #ff6a45;
}

.poi-address {
  font-size: 24rpx;
  line-height: 1.5;
  color: #999999;
}

.poi-address-active {
  color: #ffb4a4;
}

.sheet-footer {
  padding-top: 18rpx;
}
