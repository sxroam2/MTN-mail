/* 分类页 - 左右分栏布局 深色风格 */
.page {
  min-height: 100vh;
  background: #000;
  display: flex;
  flex-direction: column;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin: 16rpx 24rpx;
  padding: 16rpx 24rpx;
  background: #2a2a2a;
  border-radius: 32rpx;
  gap: 12rpx;
}
.search-placeholder {
  font-size: 26rpx;
  color: #999;
}

/* 主体容器 */
.main-wrap {
  flex: 1;
  display: flex;
  overflow: hidden;
  height: calc(100vh - 100rpx - env(safe-area-inset-bottom) - 100rpx);
}

/* 左侧分类导航 */
.sidebar {
  width: 180rpx;
  flex-shrink: 0;
  background: #1a1a1a;
  height: 100%;
}
.sidebar-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 12rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
  background: transparent;
}
.sidebar-item.active {
  background: #2a2a2a;
  color: #fff;
  font-weight: 600;
}
.sidebar-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background: #ff6a45;
  border-radius: 0 6rpx 6rpx 0;
}
.sidebar-text {
  line-height: 1.3;
  word-break: break-all;
}

/* 右侧商品列表 */
.content {
  flex: 1;
  background: #000;
  height: 100%;
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
}

.category-title {
  font-size: 28rpx;
  color: #999;
  padding: 20rpx 24rpx 8rpx;
}

.content-loading {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #000;
  z-index: 10;
  box-sizing: border-box;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-text {
  color: #999;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 商品列表 */
.product-list {
  padding: 0 20rpx;
}

.product-card {
  display: flex;
  padding: 24rpx 0;
  position: relative;
}
.product-card + .product-card {
  margin-top: 8rpx;
}
.card-hover {
  background: #1a1a1a;
}

/* 左侧图片区 */
.card-img-wrap {
  position: relative;
  flex-shrink: 0;
  margin-right: 20rpx;
}
.soldout-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}
.soldout-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  background: rgba(0,0,0,0.5);
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
}
.flash-badge {
  position: absolute;
  bottom: 10rpx;
  left: 10rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

/* 标签行 */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}
.tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  line-height: 1.5;
}
.tag-new {
  background: rgba(255, 106, 69, 0.15);
  color: #ff6a45;
  border: 1rpx solid rgba(255, 106, 69, 0.3);
}
.tag-flash {
  background: rgba(255, 77, 79, 0.15);
  color: #ff4d4f;
  border: 1rpx solid rgba(255, 77, 79, 0.3);
}

/* 右侧信息区 */
.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 220rpx;
  position: relative;
}
.card-title {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.4;
  display: -webkit-box;
  line-clamp: 2;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-bottom {
  margin-top: auto;
}
.card-price-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}
.card-price {
  font-size: 34rpx;
  color: #ff6a45;
  font-weight: bold;
}
.card-original-price {
  font-size: 22rpx;
  color: #666;
  text-decoration: line-through;
}

/* 购物车按钮 */
.card-cart-btn {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 106, 69, 0.4);
  border-radius: 50%;
  background: rgba(255, 106, 69, 0.1);
}
.card-cart-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}

/* 上拉提示 */
.load-more-tip {
  text-align: center;
  font-size: 24rpx;
  color: #666;
  padding: 30rpx 0 50rpx;
}


