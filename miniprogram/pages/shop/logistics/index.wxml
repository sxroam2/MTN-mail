<!-- 物流轨迹详情页 -->
<view class="page">
  <van-loading wx:if="{{ loading }}" size="36px" color="#ff6a45" vertical class="page-loading">加载中...</van-loading>

  <block wx:else>
    <view class="hero-card">
      <view class="hero-card__head">
        <text class="hero-card__eyebrow">物流追踪</text>
        <text class="hero-card__status {{ latestTrace ? 'is-active' : '' }}">{{ logistics.statusText }}</text>
      </view>

      <view class="hero-card__main">
        <view class="hero-card__icon">
          <van-icon name="logistics" size="22px" color="#ff6a45" />
        </view>
        <view class="hero-card__info">
          <text class="hero-card__company">{{ logistics.logisticsCompany || '物流公司' }}</text>
          <view class="hero-card__no-row">
            <text class="hero-card__no">运单号：{{ logistics.logisticsNo || '待生成' }}</text>
            <text wx:if="{{ logistics.logisticsNo }}" class="copy-btn" bindtap="copyLogisticsNo">复制</text>
          </view>
        </view>
      </view>

      <view wx:if="{{ latestTrace }}" class="hero-card__latest">
        <text class="hero-card__latest-label">最新轨迹</text>
        <text class="hero-card__latest-text">{{ latestTrace.content }}</text>
        <text class="hero-card__latest-time">{{ latestTrace.time }}</text>
      </view>
    </view>

    <view wx:if="{{ traces.length > 0 }}" class="trace-card">
      <view class="trace-card__head">
        <text class="trace-card__title">物流轨迹</text>
        <text class="trace-card__meta">共 {{ traceCount }} 条</text>
      </view>

      <view
        wx:for="{{ traces }}"
        wx:key="index"
        class="trace-item {{ index === 0 ? 'is-active' : '' }}"
      >
        <view class="trace-timeline">
          <view class="trace-dot {{ index === 0 ? 'trace-dot--active' : '' }}"></view>
          <view wx:if="{{ index < traces.length - 1 }}" class="trace-line"></view>
        </view>

        <view class="trace-content">
          <view class="trace-content__head">
            <text class="trace-text">{{ item.content }}</text>
            <text wx:if="{{ index === 0 }}" class="trace-tag">最新</text>
          </view>
          <text class="trace-time">{{ item.time }}</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-card">
      <view class="empty-card__icon">
        <van-icon name="logistics" size="34px" color="#666" />
      </view>
      <text class="empty-card__title">暂无物流轨迹</text>
      <text class="empty-card__desc">物流公司接单后，最新轨迹会显示在这里。</text>
    </view>
  </block>
</view>
