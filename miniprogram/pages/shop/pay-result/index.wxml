<!-- 支付结果页 -->
<view class="page">
  <view class="result-wrap">
    <block wx:if="{{ status === 'checking' }}">
      <van-icon name="clock-o" size="80px" color="#ffb54d" />
      <text class="result-title">正在确认支付结果</text>
      <text class="result-desc">{{ checkMessage }}</text>
      <text wx:if="{{ checkAttempts > 0 }}" class="check-progress">已确认 {{ checkAttempts }} / {{ maxCheckAttempts }} 次</text>
    </block>

    <!-- 成功状态 -->
    <block wx:elif="{{ status === 'success' }}">
      <van-icon name="checked" size="80px" color="#52c41a" />
      <text class="result-title">支付成功</text>
      <text class="result-desc">您的订单已支付成功，我们将尽快安排处理</text>
    </block>

    <!-- 失败/取消状态 -->
    <block wx:else>
      <van-icon name="warning-o" size="80px" color="#ff6a45" />
      <text class="result-title">支付未完成</text>
      <text class="result-desc">{{ checkMessage }}</text>
    </block>

    <!-- 订单号 -->
    <view wx:if="{{ orderNo }}" class="order-no-row">
      <text class="order-no-label">订单号：</text>
      <text class="order-no-value">{{ orderNo }}</text>
    </view>

    <view class="result-tips">
      <text class="tip-item">支付完成后，订单状态可能会有几秒延迟。</text>
      <text class="tip-item">如果页面未刷新，可重新检查，或先进入订单详情查看。</text>
    </view>

    <!-- 操作按钮 -->
    <view class="action-btns">
      <block wx:if="{{ status === 'checking' }}">
        <van-button
          round
          block
          color="linear-gradient(90deg, #ff6a45, #ff4d4f)"
          loading="{{ isChecking }}"
          bindtap="recheckStatus"
        >重新检查支付结果</van-button>
        <van-button
          round
          block
          plain
          color="#999"
          custom-style="margin-top: 20rpx;"
          bindtap="viewOrder"
        >查看订单</van-button>
        <van-button
          round
          block
          plain
          color="#999"
          custom-style="margin-top: 20rpx;"
          bindtap="continueShopping"
        >继续购物</van-button>
      </block>

      <block wx:elif="{{ status === 'success' }}">
        <van-button
          round
          block
          color="linear-gradient(90deg, #ff6a45, #ff4d4f)"
          bindtap="viewOrder"
        >查看订单</van-button>
        <van-button
          round
          block
          plain
          color="#999"
          custom-style="margin-top: 20rpx;"
          bindtap="continueShopping"
        >继续购物</van-button>
      </block>

      <block wx:else>
        <van-button
          round
          block
          color="linear-gradient(90deg, #ff6a45, #ff4d4f)"
          loading="{{ isChecking }}"
          bindtap="retryPay"
        >继续支付</van-button>
        <van-button
          round
          block
          plain
          color="#999"
          custom-style="margin-top: 20rpx;"
          bindtap="viewOrder"
        >查看订单</van-button>
        <van-button
          round
          block
          plain
          color="#999"
          custom-style="margin-top: 20rpx;"
          bindtap="continueShopping"
        >继续购物</van-button>
      </block>
    </view>
  </view>
</view>
