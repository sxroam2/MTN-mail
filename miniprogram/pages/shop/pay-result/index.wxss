/* 支付结果页 - 深色风格 */
.page {
  min-height: 100vh;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx;
  width: 100%;
  box-sizing: border-box;
}

.result-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  margin-top: 30rpx;
}

.result-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
  text-align: center;
  line-height: 1.7;
}

.check-progress {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #ffb54d;
}

.order-no-row {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.order-no-label {
  color: #999;
}

.order-no-value {
  color: #ccc;
}

.result-tips {
  width: 100%;
  margin-top: 28rpx;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  box-sizing: border-box;
}

.tip-item {
  display: block;
  color: #8f8f8f;
  font-size: 22rpx;
  line-height: 1.7;
}

.tip-item + .tip-item {
  margin-top: 8rpx;
}

.action-btns {
  width: 100%;
  margin-top: 60rpx;
  padding: 0 40rpx;
}
